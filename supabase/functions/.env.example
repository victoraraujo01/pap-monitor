# Secrets das Edge Functions (NÃO commitar valores reais).
# Local: passe com `supabase functions serve daily-pl --env-file supabase/functions/.env`
# Prod:  `supabase secrets set PAP_CRON_SECRET=...`

# Segredo compartilhado que protege a função quando acionada pelo cron.
# Deve ser igual ao app_config.daily_pl_cron_secret (ver migração de schedule).
PAP_CRON_SECRET=

# Sobrescreve o endpoint de preços (default = CSV do Tesouro Transparente).
# Útil para testes com um mock servindo um CSV no mesmo formato (8 colunas ';').
# TESOURO_API_URL=https://www.tesourotransparente.gov.br/ckan/dataset/df56aa42-484a-4a59-8184-7676580c81e3/resource/796d2059-14e9-44e3-80c9-2d9e30b405c1/download/PrecoTaxaTesouroDireto.csv

# A fonte de preços (Tesouro Transparente) é pública e sem token.
# SUPABASE_URL e SUPABASE_SERVICE_ROLE_KEY são injetados pelo runtime — não setar.
