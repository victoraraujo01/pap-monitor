# Secrets das Edge Functions (NÃO commitar valores reais).
# Local: passe com `supabase functions serve daily-pl --env-file supabase/functions/.env`
# Prod:  `supabase secrets set BRAPI_TOKEN=... PAP_CRON_SECRET=...`

# Token da brapi (https://brapi.dev) para GET /api/v2/treasury/list.
BRAPI_TOKEN=

# Segredo compartilhado que protege a função quando acionada pelo cron.
# Deve ser igual ao app_config.daily_pl_cron_secret (ver migração de schedule).
PAP_CRON_SECRET=

# Sobrescreve o endpoint de preços (default = brapi). Útil para testes com mock
# no formato brapi: {results:[{symbol,bondType,maturityDate,sellPrice,...}]}.
# TESOURO_API_URL=https://brapi.dev/api/v2/treasury/list

# SUPABASE_URL e SUPABASE_SERVICE_ROLE_KEY são injetados pelo runtime — não setar.
