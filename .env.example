# Credenciais do Supabase expostas ao frontend (Vite injeta apenas vars com prefixo VITE_).
# Local (após `npm run db:start`, copie os valores impressos no terminal):
#   VITE_SUPABASE_URL=http://127.0.0.1:54321
#   VITE_SUPABASE_ANON_KEY=<anon key local>
# Produção: pegue em Supabase Dashboard > Project Settings > API.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
